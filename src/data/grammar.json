[
  {
    "id": "g001",
    "pattern": "〜にもかかわらず",
    "meaning": "尽管...但是...",
    "explanation": "表示前后项相反,尽管有前项的情况,但还是出现了后项的结果。",
    "examples": [
      {
        "japanese": "雨が降っていたにもかかわらず、彼は外出した。",
        "translation": "尽管下着雨,他还是外出了。"
      },
      {
        "japanese": "勉強しなかったにもかかわらず、試験に合格した。",
        "translation": "尽管没学习,但考试还是及格了。"
      }
    ],
    "level": "N1",
    "category": "譲歩",
    "tags": [
      "逆接",
      "譲歩"
    ]
  },
  {
